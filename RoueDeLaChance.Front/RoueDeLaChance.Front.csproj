    <Exec Command="cmd /c npm run build" WorkingDirectory="$(MSBuildProjectDirectory)" ContinueOnError="true" />
    <Exec Command="cmd /c npm run copy-static" WorkingDirectory="$(MSBuildProjectDirectory)" ContinueOnError="true" />
    <Message Text="✅ Front-end build complete" Importance="high" />
  </Target> -->

  <!-- Include npm files in Solution Explorer -->
  <ItemGroup>
    <None Include="package.json" />
    <None Include="tsconfig.json" />
    <None Include=".gitignore" />
    <None Include="index.html" />
    <None Include="README.md" />
    <None Include="copy-static.js" />
    <None Include="css\**" />
    <None Include="src\**" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="css\" />
    <Folder Include="src\" />
  </ItemGroup>

</Project>
