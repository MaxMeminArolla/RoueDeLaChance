<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- This is a build-only project, not a real .NET app -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);MSB4803</NoWarn>
  </PropertyGroup>

  <!-- Optional: Build front-end before project build (requires Node.js) -->
  <!-- To enable: uncomment and ensure npm is in PATH -->
  <!-- <Target Name="BuildFrontEnd" BeforeTargets="Build">
    <Message Text="🔨 Building front-end with npm..." Importance="high" />
